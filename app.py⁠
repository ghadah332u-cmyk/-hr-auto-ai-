import streamlit as st

st.set_page_config(page_title="HR-Auto AI - نظام التوظيف الذكي", layout="wide")

st.title("🇸🇦 HR-Auto AI: نظام تقييم السير الذاتية ومطابقة الوظائف في السعودية")
st.write("منصة ذكية تدمج تحليل الكفاءات، ربط الكوادَر بأبرز الشركات في المملكة، وتوفير المسارات الوظيفية.")

# القوائم والبيانات المتاحة في السوق السعودي ضمن النظام
saudi_sectors = {
    "التقنية وتكنولوجيا المعلومات": ["STC", "ELM", "HungerStation", "Noon", "سدافكو"],
    "القطاع المالي والمصرفي": ["الراجحي", "الأهلي السعودي", "البنك السعودي الفرنسي", "الرياض"],
    "الطاقة والصناعة": ["أرامكو السعودية", "سابك", "معادن", "أسهام"],
    "التجزئة والخدمات": ["جرير", "بنده", "الدانوب", "العثيم"]
}

# شريط جانبي للتنقل
menu = st.sidebar.selectbox("اختر القسم", ["تحليل السيرة الذاتية (CV)", "تقييم الجدارة القيادية"])

if menu == "تحليل السيرة الذاتية (CV)":
    st.header("رفع وتحليل السيرة الذاتية بالذكاء الاصطناعي")
    
    uploaded_file = st.file_uploader("ارفع سيرتك الذاتية (PDF أو TXT)", type=["pdf", "txt"])
    target_sector = st.selectbox("اختر القطاع المستهدف في السعودية", list(saudi_sectors.keys()))
    
    if uploaded_file is not None:
        st.success("تم رفع الملف بنجاح! جاري التحليل...")
        st.info(f"القطاع المستهدف: {target_sector}")
        st.write("الشركات المقترحة لمطابقة سيرتك الذاتية:")
        for company in saudi_sectors[target_sector]:
            st.write(f"- {company}")

elif menu == "تقييم الجدارة القيادية":
    st.header("تقييم الجدارة القيادية والإدارية")
    st.write("هنا يمكنك تقييم المهارات الإدارية والقيادية الخاصة بك.")
